library(Seurat)

qry <- readRDS("/Volumes/T7 Shield/Razan_pathogen/Data/Patho_Nonpatho_integration_07072025.Rds")

qry_seurat_rename <- RenameIdents(object = qry, '0' = "0:Meristem_1", '1' = "1:Initial_cells", 
                                  '2' = "2:Meristem_2", '3'= "3:Companion_cell", '4'= "4:Atrichoblast", 
