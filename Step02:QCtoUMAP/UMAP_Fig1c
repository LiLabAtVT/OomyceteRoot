                                  '8' = "8:Cortex", '9' = "9:G2M_phase", '10'= "10:Endodermis", '11' = "11:Trichoblast")

# Plot the UMAP with cell type annotation

DimPlot(qry_seurat_rename, reduction = "umap", label = TRUE, label.color = "black", label.size = 5) + NoLegend() 
pdf("/Volumes/T7 Shield/Razan_pathogen/Figure/UMAP_finalanno_041726.pdf", width = 7.5, height = 5)
